{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flash-cards",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-05-17",
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
